# Copy to .env and fill in. Only ANTHROPIC_API_KEY is needed for AI analysis;
# everything else has sensible defaults.

# --- product ---
PRODUCT_NAME=Website Doctor AI

# --- AI (Phase 2) ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6        # or claude-opus-4-8 for the deepest analysis
AI_MAX_TOKENS=12000

# --- performance: Google PageSpeed Insights (Core Web Vitals) ---
# Works without a key at low volume; set one for higher quota:
GOOGLE_PSI_API_KEY=

# --- crawler (Phase 1) ---
USER_AGENT=WebsiteAuditBot/1.0 (+https://example.com)
REQUEST_TIMEOUT=15
CRAWL_CONCURRENCY=8
LINK_CHECK_CONCURRENCY=20

# --- database (Phase 5, optional) ---
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/audit

# --- white-label branding (Phase 3) ---
AGENCY_NAME=Your Agency
AGENCY_LOGO_URL=
AGENCY_PRIMARY_COLOR=#2563eb
AGENCY_WEBSITE=https://example.com
AGENCY_EMAIL=hello@example.com

# --- server ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
